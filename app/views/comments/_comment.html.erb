<li class="list-group-item" id="dom_id(comment) %>">
  <div class="d-flex">
    <div class="flex-shrink-0">
      <%= image_tag comment.author.avatar_image, class: "rounded-circle me-2", width: 36 %>
    </div>
    <div class="flex-grow-1 ms-3">
      <div class="d-flex align-items-center justify-content-between">
        <h5 class="mt-0">
          <%= link_to comment.author.username, user_path(comment.author.username), class: "text-dark link-underline-dark link-underline-opacity-0 link-underline-opacity-100-hover", data: { turbo: false } %>
        </h5>

        <div>
          <% if comment.author == current_user %>
            <%= link_to edit_comment_path(comment), class: "btn btn-link btn-sm text-muted" do %>
              <i class="fas fa-edit fa-fw"></i>
            <% end %>

            <%= link_to "#", class: "btn btn-link btn-sm text-muted", id: "#comment_{comment.id}_delete_link" do %>
              <i class="fas fa-trash fa-fw"></i>
            <% end %>
          <% end %>
        </div>
      </div>
      <p><%= comment.body %></p>
    </div>
  </div> 
</li>

<script>
  $("#comment_<%= comment.id %>_delete_link").on("click", function() {
    $.ajax({
      url: "/comments/<%= comment.id %>",
      type: "DELETE",
      dataType: "script"
    });
    return false;
  });
</script>
